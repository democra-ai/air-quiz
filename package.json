{
  "name": "air-quiz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "cf:preview": "opennextjs-cloudflare build && wrangler pages dev",
    "cf:deploy": "opennextjs-cloudflare build && wrangler pages deploy .open-next/assets --project-name=air",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:d1:apply:local": "wrangler d1 migrations apply AIR_DB --local",
    "cf:d1:apply:remote": "wrangler d1 migrations apply AIR_DB --remote"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@opennextjs/cloudflare": "^1.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.564.0",
    "modern-screenshot": "^4.6.8",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-notion-avatar": "^1.1.12",
    "react-peeps": "^0.1.10",
    "recharts": "^3.7.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250115.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.0.0"
  }
}
